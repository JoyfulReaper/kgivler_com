<?xml version="1.0" encoding="UTF-8"?>
<configuration>
	<system.webServer>

		<security>
			<requestFiltering removeServerHeader="true">
				<hiddenSegments>
					<remove segment="config.env" />
					<remove segment=".aws" />
					<remove segment=".git" />
				</hiddenSegments>
			</requestFiltering>
		</security>

		<rewrite>
		<rules>
			<rule name="Gone old teen board" stopProcessing="true">
			<match url="^teens/tboard/.*" ignoreCase="true" />
			<action
				type="CustomResponse"
				statusCode="410"
				statusReason="Gone"
				statusDescription="This ancient cursed PHP fossil is gone." />
			</rule>

			<rule name="Gone old Liero page" stopProcessing="true">
			<match url="^liero(/.*)?$" ignoreCase="true" />
			<action
				type="CustomResponse"
				statusCode="410"
				statusReason="Gone"
				statusDescription="The old Liero page is gone." />
			</rule>

			<rule name="GlobalPhpTrap" stopProcessing="true">
			<match url="\.php$" ignoreCase="true" />
			<action type="Rewrite" url="wp_admin_fake.txt" />
			</rule>
		</rules>
		</rewrite>

		<httpProtocol>
			<customHeaders>
				<remove name="X-Powered-By" />
			</customHeaders>
		</httpProtocol>

		<httpErrors errorMode="Custom" existingResponse="Replace">
			<remove statusCode="404" subStatusCode="-1" />
			<error statusCode="404" path="/404.html" responseMode="ExecuteURL" />

			<remove statusCode="500" subStatusCode="-1" />
			<error statusCode="500" path="/500.html" responseMode="ExecuteURL" />
		</httpErrors>

		<staticContent>
			<remove fileExtension=".env" />
			<mimeMap fileExtension=".env" mimeType="text/plain" />

			<remove fileExtension=".json" />
			<mimeMap fileExtension=".json" mimeType="application/json" />

			<remove fileExtension=".production" />
			<mimeMap fileExtension=".production" mimeType="text/plain" />

			<remove fileExtension=".local" />
			<mimeMap fileExtension=".local" mimeType="text/plain" />

			<remove fileExtension="." />
			<mimeMap fileExtension="." mimeType="text/plain" />
		</staticContent>

	</system.webServer>
</configuration>